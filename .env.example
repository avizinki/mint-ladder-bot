# Helius-first (CEO directive): Helius is primary data infrastructure. Required for run.
# Get key: https://dashboard.helius.dev
HELIUS_API_KEY=
# Enhanced Transactions API base (optional; default api-mainnet.helius-rpc.com)
HELIUS_API_URL=https://api-mainnet.helius-rpc.com
# Wallet for Helius probe (optional if status.json exists)
# WALLET=your_solana_wallet_pubkey

# RPC: Helius as primary. Same key as above in URL for RPC calls.
# RPC_PRIMARY used for backfill; RPC_ENDPOINT for live (can point to same Helius endpoint).
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
RPC_PRIMARY=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# Tx-backfill: RPC pool failover (CEO directive §2).
RPC_BACKFILL_POOL=https://rpc.ankr.com/solana,https://api.mainnet-beta.solana.com
TRADING_BAG_PCT=0.20
SLIPPAGE_BPS=75
MIN_TRADE_SOL=0.01
CHECK_INTERVAL_SEC=15
MAX_RETRIES=5
PRICE_STALE_THRESHOLD_SEC=20
LIQUIDITY_WARN_THRESHOLD_USD=5000
MAX_SELL_BAG_FRACTION_PER_HOUR=1.0
# Per-24h sell cap: max fraction of trading bag sellable in 24h (Risk-tunable).
MAX_SELL_BAG_FRACTION_PER_24H=2.0
FAIL_PAUSE_MINUTES=10

# RPC cooldown: consecutive failures before global pause, and pause duration (sec).
# RPC_FAILURES_THRESHOLD=5
# RPC_COOLDOWN_SEC=120
# Per-mint pause: consecutive failures before mint is paused.
# MAX_CONSECUTIVE_FAILURES=3
# Quote staleness: max age in seconds before quote is rejected.
# QUOTE_MAX_AGE_SEC=5

# Re-anchoring: cycles price must stay above 1.5x working entry before raising anchor; cooldown and per-24h cap.
REANCHOR_CYCLES_REQUIRED=3
REANCHOR_COOLDOWN_HOURS=24
REANCHOR_MAX_PER_24H=2

# Pump detection: short-term positive return thresholds (%). Used for mode/guards later.
# PUMP_THRESHOLD_1M_PCT=10
# PUMP_THRESHOLD_5M_PCT=20

# Micro-sell fracturing: split one step into N smaller sells when liquidity is below threshold (execution shape only).
# MICRO_SELL_FRACTURE_N=1
# MICRO_SELL_FRACTURE_WHEN_LIQUIDITY_BELOW_USD=100000
# MICRO_SELL_FRACTURE_DELAY_SEC=2

# Rug / liquidity-collapse guard: pause mint when liquidity disappears or drops sharply.
# LIQUIDITY_COLLAPSE_DROP_PCT=0.50
# LIQUIDITY_COLLAPSE_PAUSE_MINUTES=60
# LIQUIDITY_COLLAPSE_MIN_REFERENCE_USD=1000

# Bootstrap buy for unknown-entry mints (one tiny SOL→token buy to establish entry from chain).
# BOOTSTRAP_BUY_SOL=0.01

# Buy-back (optional; default off). When price drops below entry, spend SOL to buy token (capped).
# BUYBACK_ENABLED=false
# BUYBACK_TRIGGER_PCT=0.10
# BUYBACK_MAX_SOL_PER_TRADE=0.01
# BUYBACK_MAX_SOL_PER_MINT=0.1
# BUYBACK_MIN_SOL=0.001
# BUYBACK_SOL_RESERVE=0.05
# BUYBACK_COOLDOWN_SEC=3600

# Jupiter Metis Swap API (https://station.jup.ag/docs/api/swap-api/)
# Option A: set JUPITER_BASE_URL (quote/swap default to {base}/swap/v1/quote and .../swap)
# Option B: set JUPITER_QUOTE_URL and JUPITER_SWAP_URL explicitly
JUPITER_BASE_URL=https://api.jup.ag
# Optional: API key from https://portal.jup.ag (sent as x-api-key header)
# JUPITER_API_KEY=...

# --- Global safety switch (CEO directive) ---
# TRADING_ENABLED=false    # Must be true to allow any swaps. Default false = safe mode (ingestion/analytics only).
# LIVE_TRADING=false       # Monitor-only default. Set true for live trading (CEO directive §11).
# --- Risk (CEO directive §4) ---
# MIN_LIQUIDITY_USD=10000
# MAX_SLIPPAGE=0.05
# MAX_SELL_SOL_PER_TRADE=0.2
# BUYBACK_SOL_RESERVE=0.5
# --- Live validation (protection-only, 1 SOL / manual buys) ---
# LIVE_PROTECTION_ONLY=1   # No autonomous buying; detect and protect only.
# TRADING_DISABLED=0       # Kill switch: set to 1 to disable all swaps (STOP file also checked).
# STOP_LOSS_PCT=0.15       # Hard stop loss: trigger sell when price <= entry * (1 - 0.15).
# BREAK_EVEN_ENABLED=0     # Optional: lock to break-even after price rises BREAK_EVEN_TRIGGER_PCT above entry.
# BREAK_EVEN_TRIGGER_PCT=0.05
# MIN_BUY_DETECTION_RAW=10000      # Ignore dust; new lot only when balance increase >= this (raw).
# MIN_LIQUIDITY_USD_FOR_TRACK=1000 # Ignore new mints with DexScreener liquidity below this.
# CIRCUIT_BREAKER_FAILURES=5       # Pause all after X consecutive failures (RPC/swap).

# Wallet secret (DO NOT COMMIT REAL KEYS)
# PRIVATE_KEY_BASE58 should be set in your shell, not in a file.
# PRIVATE_KEY_BASE58=...

# Hard reset / clean start: set to 1 to start with zero lots (no migration, no tx-first, no buy detection).
# Use after archive/hard_reset; clear to resume normal lot creation from wallet.
# CLEAN_START=0

# Tx-first ledger: deeper scan for transaction-derived lots (no tradable lot without tx_signature).
# TX_FULL_LEDGER=1       # Use full signature window (ENTRY_SCAN_MAX_SIGNATURES) at startup instead of default.
# TX_BACKFILL_ONCE=1     # One-off backfill with larger window (creates .tx_backfill_done sentinel).
# TX_BACKFILL_SIGNATURES=200   # Max signatures for backfill (capped 100–500).

# Founder notifications (optional). Do not commit real values.
# Prefer: TG_BOT_TOKEN, TG_CHAT_ID, TG_NOTIFICATIONS_ENABLED (notifier.py).
# Fallback: TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID (tools/notify_founder.py, scripts).
# TG_BOT_TOKEN=        # Same as TELEGRAM_BOT_TOKEN
# TG_CHAT_ID=          # Same as TELEGRAM_CHAT_ID (default chat for reports/alerts)
# TG_NOTIFICATIONS_ENABLED=true   # false = no Telegram sends (bot never fails if missing)
# TELEGRAM_BOT_TOKEN=   # Bot token from @BotFather
# TELEGRAM_CHAT_ID=    # Founder chat ID (e.g. from getUpdates)

# Port registry (docs/PORT_REGISTRY.md, config/ports.yaml). Dashboard uses 6200 by default; auto-shifts within 6200–6299 if taken.
# PORT_DASHBOARD_HTTP=6200   # Dashboard HTTP (default from registry). Legacy: PORT_8765 overrides when set.

# Telegram command center (integration/): owner and team for /pause, /resume, /rebuild, etc.
# TELEGRAM_OWNER_ID=   # Your numeric Telegram user ID (full commands). Get from getUpdates when you message the bot.
# TELEGRAM_TEAM_IDS=   # Comma-separated user IDs for team (pause, resume, logs; no rebuild)
# TELEGRAM_CONTEXT_MAX_MESSAGES=5000   # Chat context retention (messages). Default 5000.
# TELEGRAM_CONTEXT_MAX_DAYS=90         # Chat context retention (days). Default 90.

# Optional: one startup validation message via report() (Telegram + event_bus + voice). Default off.
# TG_STARTUP_TEST_MESSAGE_ENABLED=false
# TG_STARTUP_TEST_MESSAGE_TEXT=hello miss jackson
# TG_STARTUP_TEST_MESSAGE_SENDER=Execution Engine

# Optional: one voice + Telegram greeting at startup (report() → Telegram + event_bus → voice). Default off.
# TG_GREETING_TEST_ENABLED=false

# Optional: team voice roll call — each role sends text + voice greeting to Telegram (report() + send_voice_message). Default off.
# TG_TEAM_GREETING_ROLLCALL=false
# TG_TEAM_GREETING_ROLLCALL_ONCE=true   # When roll call enabled: run once (sentinel file), do not spam on restart.
# TG_TEAM_GREETING_OWNER_NAME=Avi       # Name used in greeting texts.
# TG_SEND_TEXT_MESSAGES=true            # Send text greetings to Telegram (default true).
# TG_SEND_VOICE_MESSAGES=true           # Send TTS voice greetings to Telegram (default true). Requires TTS_ENABLED and ffmpeg for wav→ogg.
# TG_VOICE_ONLY_FOR_ROLLCALL=           # Optional: if set true, voice only sent during roll call (no change to event_bus→voice routing).

# Role-aware auto-reply: when Avi replies to a role message, that same role answers (permanent owner-facing feature).
TG_ROLE_AUTO_REPLY_ENABLED=true
TG_ROLE_AUTO_REPLY_OWNER_ONLY=true
TG_ROLE_AUTO_REPLY_VOICE=true
TG_ROLE_AUTO_REPLY_DEFAULT_ROLE=Execution Engine
TG_ROLE_AUTO_REPLY_REQUIRE_REPLY_CONTEXT=true
TG_ROLE_AUTO_REPLY_COOLDOWN_SECONDS=3
# TELEGRAM_OWNER_ID=   # REQUIRED when OWNER_ONLY=true. Your numeric Telegram user ID (get from getUpdates or @userinfobot).
# TG_OWNER_ID=         # Alias for TELEGRAM_OWNER_ID.
# TG_ROLE_AUTO_REPLY_MAX_RECENT_LOOKBACK=100
# TG_ROLE_AUTO_REPLY_ALLOWED_CHAT_IDS=   # Comma-separated; empty = allow all.

# First interaction pack: intro + one reply-inviting prompt per role (sent after startup or via /firstpack).
TG_FIRST_INTERACTION_PACK_ENABLED=true
TG_FIRST_INTERACTION_PACK_ONCE=true
TG_FIRST_INTERACTION_PACK_INCLUDE_VOICE=true
# TG_FIRST_INTERACTION_PACK_OWNER_NAME=Avi

# Telegram send: text and voice for role replies and first pack.
# TG_SEND_TEXT_MESSAGES=true
# TG_SEND_VOICE_MESSAGES=true
# TG_TEAM_GREETING_ROLLCALL=false
# TG_VOICE_ONLY_FOR_ROLLCALL=false
# TTS_OUTPUT_MODE=telegram_voice_and_text
# TTS_LOCAL_PLAYBACK_DEBUG=false

# Webhook bridge (integration/webhook_bridge.py): OFF | LOCAL_EXPORT_ONLY | OUTBOUND_WEBHOOK | INBOUND_AND_OUTBOUND
# WEBHOOK_MODE=OFF
# WEBHOOK_TARGET_URL=    # POST URL for outbound summaries
# WEBHOOK_SHARED_SECRET= # Optional HMAC-SHA256 signing (no secrets in payload)
# WEBHOOK_TIMEOUT_SECONDS=15
# WEBHOOK_RETRY_COUNT=2
# WEBHOOK_BIND_HOST=127.0.0.1
# WEBHOOK_BIND_PORT=   # Optional; when unset, port from registry (config/ports.yaml) telegram_webhook=6300.
# WEBHOOK_DATA_DIR=   # Data dir for inbound action (state/status path). Default from runner when in-process.

# --- Sniper (entry engine) — optional autonomous buy pipeline ---
# SNIPER_ENABLED=false           # Set true to run detect → filter → buy → confirm_fill → lot → ladder (one buy per cycle when gated).
# SNIPER_TEST_MINTS=             # Comma-separated mints for dry-run / test (no PUMPFUN URL needed).
# SNIPER_BUY_SOL=0.02            # SOL per sniper buy when eligible.
# SNIPER_MAX_CONCURRENT_LOTS=5   # Skip new buys when total lots >= this.
# SNIPER_COOLDOWN_SECONDS=30     # Min seconds between sniper buys.
# SNIPER_SKIP_EXISTING_MINTS=true  # Do not buy mints already in state (default true).
# SNIPER_MIN_SOL_RESERVE=0.1     # Do not buy if wallet SOL below this.
# PUMPFUN_NEW_TOKENS_URL=        # Optional: URL for new pump.fun launches (JSON array or { data: [...] }).
# PUMPFUN_API_KEY=               # Optional: API key for pump.fun endpoint.
# PUMPFUN_POLL_INTERVAL_SECONDS=30  # Rate limit: min seconds between pump.fun fetches (dedupe also applied).

# --- Local TTS (Telegram voice = primary; Mac playback = optional debug) ---
# TTS_ENABLED=false              # Set true to enable TTS (required for roll-call voice to Telegram).
# TTS_PROVIDER=auto              # auto | piper | kokoro (auto prefers Piper).
# TTS_OUTPUT_MODE=speak          # speak | file | both. Use telegram_voice_and_text to prefer Telegram voice + text (roll call sends both).
# TTS_LOCAL_PLAYBACK_DEBUG=false # Optional: set true for local Mac playback in addition to Telegram (debug only).
# TTS_DEFAULT_VOICE=             # Provider default if not set.
# TTS_COOLDOWN_SECONDS=2         # Min seconds between phrases.
# TTS_MAX_QUEUE=20               # Max queued phrases; oldest dropped when full.
# TTS_DUPLICATE_COOLDOWN_SECONDS=30  # Same phrase within this window suppressed.
# TTS_SPEAK_STARTUP=true         # Speak startup message.
# TTS_SPEAK_TRADES=true          # Speak buy/sell confirmations.
# TTS_SPEAK_WARNINGS=true        # Speak critical warnings (RPC pause, etc.).
# TTS_QUIET_HOURS_START=23:00    # Optional: no non-critical TTS until end (e.g. 07:00).
# TTS_QUIET_HOURS_END=07:00      # RPC_FAILOVER, GLOBAL_PAUSE, CRITICAL_WARNING always allowed.
# Voice profiles (defaults used if unset): VOICE_PROFILE_CTO=, VOICE_PROFILE_DEVOPS=, VOICE_PROFILE_EXECUTION=, VOICE_PROFILE_RISK=, VOICE_PROFILE_QA=
# PIPER_PATH=                    # Path to piper binary if not in PATH.
# MINT_LADDER_PROJECT_ROOT=      # Project root (runtime/voice, logs/voice).

